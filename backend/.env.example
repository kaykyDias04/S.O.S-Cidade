# ===========================================
# SOS-Cidade Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Database (Supabase) ---
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# --- Redis (Upstash) ---
# Get from: https://console.upstash.com → Your Database → Connect → ioredis
REDIS_URL="rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6380"

# --- Auth ---
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET="change-me-to-a-very-long-random-secret"

# --- CORS ---
# Your Vercel frontend URL(s), comma-separated
FRONTEND_URL="https://sos-cidade-front.vercel.app"

# --- Server ---
PORT=8000
NODE_ENV=production
