{
  "expo": {
    "name": "S.O.S Cidade",
    "slug": "sos-cidade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "soscidade",
    "newArchEnabled": false,
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soscidade.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6498c9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.soscidade.mobile",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "S.O.S Cidade usa sua localização para identificar o bairro da ocorrência.",
          "locationWhenInUsePermission": "S.O.S Cidade usa sua localização para identificar o bairro da ocorrência."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "S.O.S Cidade precisa de acesso às suas fotos para anexar imagens às denúncias.",
          "cameraPermission": "S.O.S Cidade precisa da câmera para fotografar a ocorrência."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "S.O.S Cidade usa a câmera para fotografar ocorrências."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "114df36c-08b7-4bc9-8bc1-f954ef5f52c4"
      }
    }
  }
}
